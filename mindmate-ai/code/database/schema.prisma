// MindMate AI - Prisma Schema
// Database Schema for Mental Health AI Companion Platform
// Generated by Agent 67

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE USER TABLES
// ============================================

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  password_hash         String
  first_name            String?
  last_name             String?
  username              String    @unique
  avatar_url            String?
  date_of_birth         DateTime?
  phone_number          String?
  timezone              String    @default("UTC")
  language              String    @default("en")
  bio                   String?
  onboarding_completed  Boolean   @default(false)
  onboarding_step       Int       @default(0)
  is_active             Boolean   @default(true)
  is_verified           Boolean   @default(false)
  email_verified_at     DateTime?
  phone_verified_at     DateTime?
  last_login_at         DateTime?
  last_active_at        DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  // Relations
  sessions              Session[]
  messages              Message[]
  emotions_log          EmotionLog[]
  tasks                 Task[]
  task_completions      TaskCompletion[]
  mood_entries          MoodEntry[]
  notifications         Notification[]
  crisis_events         CrisisEvent[]
  memory_entries        MemoryEntry[]
  subscriptions         Subscription[]
  therapist_notes       TherapistNote[]
  emergency_contacts    EmergencyContact[]
  progress_reports      ProgressReport[]
  user_challenges       UserChallenge[]
  user_achievements     UserAchievement[]

  @@index([email])
  @@index([username])
  @@index([is_active])
  @@index([created_at])
  @@map("users")
}

model Session {
  id           String    @id @default(uuid())
  user_id      String
  token        String    @unique
  refresh_token String?  @unique
  device_info  String?
  ip_address   String?
  user_agent   String?
  expires_at   DateTime
  created_at   DateTime  @default(now())
  last_active_at DateTime @default(now())
  is_valid     Boolean   @default(true)

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
  @@index([expires_at])
  @@map("sessions")
}

// ============================================
// MESSAGING & AI INTERACTION
// ============================================

model Message {
  id                String   @id @default(uuid())
  user_id           String
  conversation_id   String?
  content           String
  role              MessageRole
  message_type      MessageType @default(TEXT)
  sentiment_score   Float?
  emotion_detected  String?
  intent_detected   String?
  ai_model_version  String?
  tokens_used       Int?
  response_time_ms  Int?
  is_flagged        Boolean  @default(false)
  flag_reason       String?
  parent_message_id String?
  metadata          Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([conversation_id])
  @@index([created_at])
  @@index([role])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
  FILE
  CRISIS_ALERT
}

// ============================================
// EMOTION & MOOD TRACKING
// ============================================

model EmotionLog {
  id              String   @id @default(uuid())
  user_id         String
  emotion         String
  intensity       Int      @db.SmallInt // 1-10 scale
  trigger         String?
  context         String?
  location        String?
  activity        String?
  notes           String?
  ai_analysis     Json?
  logged_at       DateTime @default(now())
  created_at      DateTime @default(now())

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([emotion])
  @@index([logged_at])
  @@map("emotions_log")
}

model MoodEntry {
  id              String   @id @default(uuid())
  user_id         String
  mood_score      Int      @db.SmallInt // 1-10 scale
  mood_label      String
  energy_level    Int?     @db.SmallInt // 1-10 scale
  sleep_quality   Int?     @db.SmallInt // 1-10 scale
  stress_level    Int?     @db.SmallInt // 1-10 scale
  journal_entry   String?
  factors         String[] // Array of mood factors
  tags            String[]
  ai_insights     Json?
  is_shared       Boolean  @default(false)
  entry_date      DateTime @db.Date
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, entry_date])
  @@index([user_id])
  @@index([entry_date])
  @@index([mood_score])
  @@map("mood_entries")
}

// ============================================
// TASKS & GOALS
// ============================================

model Task {
  id                String     @id @default(uuid())
  user_id           String
  title             String
  description       String?
  task_type         TaskType   @default(PERSONAL)
  priority          Priority   @default(MEDIUM)
  status            TaskStatus @default(PENDING)
  due_date          DateTime?
  reminder_at       DateTime?
  recurrence_rule   String?    // iCal RRULE format
  estimated_minutes Int?
  actual_minutes    Int?
  category          String?
  tags              String[]
  ai_suggested      Boolean    @default(false)
  ai_reasoning      String?
  parent_task_id    String?
  metadata          Json?
  completed_at      DateTime?
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  user              User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  completions       TaskCompletion[]

  @@index([user_id])
  @@index([status])
  @@index([due_date])
  @@index([task_type])
  @@map("tasks")
}

model TaskCompletion {
  id              String   @id @default(uuid())
  task_id         String
  user_id         String
  completed_at    DateTime @default(now())
  completion_notes String?
  mood_at_completion Int?  @db.SmallInt
  difficulty_rating  Int?  @db.SmallInt // 1-5 scale
  feedback        String?
  xp_earned       Int      @default(0)

  task            Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([user_id])
  @@index([completed_at])
  @@map("task_completions")
}

enum TaskType {
  PERSONAL
  THERAPY
  WELLNESS
  MEDICATION
  EXERCISE
  SOCIAL
  WORK
  AI_SUGGESTED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DEFERRED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id              String           @id @default(uuid())
  user_id         String
  template_id     String?
  title           String
  body            String
  notification_type NotificationType
  priority        Priority         @default(MEDIUM)
  channel         NotificationChannel @default(IN_APP)
  action_url      String?
  action_label    String?
  image_url       String?
  data            Json?
  is_read         Boolean          @default(false)
  read_at         DateTime?
  sent_at         DateTime?
  delivered_at    DateTime?
  clicked_at      DateTime?
  scheduled_for   DateTime?
  created_at      DateTime         @default(now())

  user            User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  template        NotificationTemplate? @relation(fields: [template_id], references: [id])

  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
  @@index([notification_type])
  @@map("notifications")
}

model NotificationTemplate {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  title_template  String
  body_template   String
  notification_type NotificationType
  default_channel NotificationChannel @default(IN_APP)
  default_priority Priority         @default(MEDIUM)
  variables       Json?            // Expected variable schema
  is_active       Boolean          @default(true)
  category        String?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  notifications   Notification[]

  @@index([notification_type])
  @@map("notification_templates")
}

enum NotificationType {
  SYSTEM
  REMINDER
  ACHIEVEMENT
  MOOD_CHECK
  TASK_DUE
  MESSAGE
  CRISIS_ALERT
  SUBSCRIPTION
  PROGRESS_UPDATE
  CHECK_IN
  WELLNESS_TIP
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
  WEBHOOK
}

// ============================================
// CRISIS & SAFETY
// ============================================

model CrisisEvent {
  id                String        @id @default(uuid())
  user_id           String
  severity          CrisisSeverity
  trigger_message_id String?
  detected_keywords String[]
  ai_confidence     Float
  user_reported     Boolean       @default(false)
  status            CrisisStatus  @default(DETECTED)
  initial_response  String?
  resolution_notes  String?
  escalated_to      String?
  resources_provided String[]
  user_location     String?
  emergency_contact_notified Boolean @default(false)
  resolved_at       DateTime?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  user              User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([severity])
  @@index([status])
  @@index([created_at])
  @@map("crisis_events")
}

enum CrisisSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CrisisStatus {
  DETECTED
  RESPONDING
  RESOLVED
  ESCALATED
  FALSE_POSITIVE
}

// ============================================
// MEMORY & CONTEXT
// ============================================

model MemoryEntry {
  id                String       @id @default(uuid())
  user_id           String
  memory_type       MemoryType
  content           String
  summary           String?
  importance_score  Float        @default(0.5)
  emotional_valence Float?       // -1 to 1
  source_message_id String?
  related_topics    String[]
  metadata          Json?
  is_active         Boolean      @default(true)
  last_accessed_at  DateTime?
  access_count      Int          @default(0)
  expires_at        DateTime?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  user              User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([memory_type])
  @@index([importance_score])
  @@index([is_active])
  @@map("memory_entries")
}

enum MemoryType {
  PREFERENCE
  FACT
  EVENT
  GOAL
  EMOTION
  RELATIONSHIP
  THERAPY_INSIGHT
  ROUTINE
}

// ============================================
// SUBSCRIPTIONS & BILLING
// ============================================

model Subscription {
  id                String             @id @default(uuid())
  user_id           String
  tier_id           String
  status            SubscriptionStatus @default(TRIAL)
  payment_provider  String?            // stripe, paypal, etc.
  payment_provider_subscription_id String?
  current_period_start DateTime
  current_period_end   DateTime
  cancel_at_period_end Boolean         @default(false)
  canceled_at       DateTime?
  trial_start       DateTime?
  trial_end         DateTime?
  amount_paid       Decimal?           @db.Decimal(10, 2)
  currency          String             @default("USD")
  invoice_url       String?
  metadata          Json?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  user              User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tier              SubscriptionTier   @relation(fields: [tier_id], references: [id])

  @@index([user_id])
  @@index([status])
  @@index([current_period_end])
  @@map("subscriptions")
}

model SubscriptionTier {
  id                String   @id @default(uuid())
  name              String   @unique
  display_name      String
  description       String?
  price_monthly     Decimal  @db.Decimal(10, 2)
  price_yearly      Decimal  @db.Decimal(10, 2)
  currency          String   @default("USD")
  features          Json     // Array of feature objects
  limits            Json     // Usage limits object
  is_active         Boolean  @default(true)
  is_popular        Boolean  @default(false)
  trial_days        Int      @default(0)
  sort_order        Int      @default(0)
  stripe_price_id_monthly String?
  stripe_price_id_yearly  String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  subscriptions     Subscription[]

  @@index([is_active])
  @@index([sort_order])
  @@map("subscription_tiers")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

// ============================================
// THERAPIST INTEGRATION
// ============================================

model TherapistNote {
  id              String   @id @default(uuid())
  user_id         String
  therapist_id    String?
  session_date    DateTime @db.Date
  note_type       NoteType @default(PROGRESS)
  content         String
  summary         String?
  mood_observation String?
  goals_discussed String[]
  action_items    String[]
  is_shared_with_user Boolean @default(false)
  user_acknowledged_at DateTime?
  tags            String[]
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([session_date])
  @@index([note_type])
  @@map("therapist_notes")
}

enum NoteType {
  PROGRESS
  SESSION
  ASSESSMENT
  TREATMENT_PLAN
  CRISIS
  COLLABORATIVE
}

// ============================================
// EMERGENCY CONTACTS
// ============================================

model EmergencyContact {
  id              String   @id @default(uuid())
  user_id         String
  name            String
  relationship    String
  phone_number    String?
  email           String?
  is_primary      Boolean  @default(false)
  can_be_notified Boolean  @default(true)
  notification_methods String[] @default(["SMS", "CALL"])
  address         String?
  notes           String?
  priority_order  Int      @default(0)
  is_active       Boolean  @default(true)
  verified_at     DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_primary])
  @@index([is_active])
  @@map("emergency_contacts")
}

// ============================================
// PROGRESS & ANALYTICS
// ============================================

model ProgressReport {
  id                String   @id @default(uuid())
  user_id           String
  report_type       ReportType @default(WEEKLY)
  period_start      DateTime @db.Date
  period_end        DateTime @db.Date
  mood_summary      Json?    // Aggregated mood data
  task_summary      Json?    // Task completion stats
  emotion_summary   Json?    // Emotion tracking summary
  insights          String[]
  recommendations   String[]
  achievements      String[]
  goals_progress    Json?    // Progress on goals
  ai_generated_content String?
  is_generated      Boolean  @default(false)
  generated_at      DateTime?
  viewed_at         DateTime?
  shared_with       String[]
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([report_type])
  @@index([period_start])
  @@index([is_generated])
  @@map("progress_reports")
}

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  SESSION
}

// ============================================
// CHALLENGES & GAMIFICATION
// ============================================

model Challenge {
  id                String   @id @default(uuid())
  name              String   @unique
  title             String
  description       String
  challenge_type    ChallengeType
  category          String
  difficulty        Difficulty @default(MEDIUM)
  requirements      Json     // Requirements to complete
  rewards           Json     // XP, badges, etc.
  duration_days     Int?
  is_active         Boolean  @default(true)
  is_default        Boolean  @default(false)
  start_date        DateTime?
  end_date          DateTime?
  max_participants  Int?
  icon_url          String?
  banner_url        String?
  sort_order        Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user_challenges   UserChallenge[]

  @@index([challenge_type])
  @@index([is_active])
  @@index([category])
  @@map("challenges")
}

model UserChallenge {
  id                String            @id @default(uuid())
  user_id           String
  challenge_id      String
  status            ChallengeStatus   @default(IN_PROGRESS)
  progress          Json              // Current progress data
  started_at        DateTime          @default(now())
  completed_at      DateTime?
  xp_earned         Int               @default(0)
  rewards_claimed   Boolean           @default(false)
  rewards_claimed_at DateTime?

  user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  challenge         Challenge         @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  @@unique([user_id, challenge_id])
  @@index([user_id])
  @@index([status])
  @@map("user_challenges")
}

enum ChallengeType {
  DAILY
  WEEKLY
  STREAK
  MILESTONE
  SOCIAL
  THERAPEUTIC
  EDUCATIONAL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum ChallengeStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  ABANDONED
}

// ============================================
// ACHIEVEMENTS & BADGES
// ============================================

model Achievement {
  id                String   @id @default(uuid())
  name              String   @unique
  title             String
  description       String
  category          String
  icon_url          String?
  requirement_type  String
  requirement_value Int
  xp_reward         Int      @default(0)
  is_hidden         Boolean  @default(false)
  is_active         Boolean  @default(true)
  sort_order        Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user_achievements UserAchievement[]

  @@index([category])
  @@index([is_active])
  @@map("achievements")
}

model UserAchievement {
  id              String   @id @default(uuid())
  user_id         String
  achievement_id  String
  earned_at       DateTime @default(now())
  xp_claimed      Boolean  @default(false)
  shared_at       DateTime?

  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievement_id], references: [id], onDelete: Cascade)

  @@unique([user_id, achievement_id])
  @@index([user_id])
  @@map("user_achievements")
}

// ============================================
// AVATAR OPTIONS
// ============================================

model AvatarOption {
  id              String     @id @default(uuid())
  name            String     @unique
  display_name    String
  description     String?
  avatar_type     AvatarType
  category        String
  asset_url       String
  thumbnail_url   String?
  is_premium      Boolean    @default(false)
  required_tier   String?    // Subscription tier required
  is_active       Boolean    @default(true)
  metadata        Json?      // Colors, styles, etc.
  sort_order      Int        @default(0)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  @@index([avatar_type])
  @@index([is_active])
  @@index([category])
  @@map("avatar_options")
}

enum AvatarType {
  CHARACTER
  ANIMAL
  ABSTRACT
  CUSTOM
  PREMIUM
}
