# MindMate AI Database Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONNECTION
# ============================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://mindmate_user:your_secure_password@localhost:5432/mindmate_db

# For local development
DATABASE_URL_LOCAL=postgresql://mindmate_user:your_secure_password@localhost:5432/mindmate_dev

# For testing
DATABASE_URL_TEST=postgresql://mindmate_user:your_secure_password@localhost:5432/mindmate_test

# For production
DATABASE_URL_PRODUCTION=postgresql://mindmate_user:your_secure_password@prod-host:5432/mindmate_prod

# ============================================
# DATABASE CONFIGURATION
# ============================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mindmate_db
DB_USER=mindmate_user
DB_PASSWORD=your_secure_password

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30000

# SSL configuration (for production)
DB_SSL_MODE=require
DB_SSL_CA_PATH=/path/to/ca-certificate.crt

# ============================================
# PRISMA CONFIGURATION
# ============================================

# Prisma Client output directory
PRISMA_CLIENT_OUTPUT=./node_modules/@prisma/client

# Enable query logging (development only)
PRISMA_LOG_QUERIES=true

# ============================================
# REDIS CONFIGURATION (for caching/sessions)
# ============================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Automated backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=mindmate-backups
BACKUP_S3_REGION=us-east-1

# ============================================
# MONITORING
# ============================================

# Enable query performance monitoring
ENABLE_QUERY_MONITORING=true
SLOW_QUERY_THRESHOLD_MS=1000
