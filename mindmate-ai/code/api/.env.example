# ============================================
# MindMate AI API - Environment Configuration
# ============================================

# Application
NODE_ENV=development
PORT=8080
API_VERSION=v1
API_PREFIX=/v1

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d
JWT_ISSUER=mindmate-ai
JWT_AUDIENCE=mindmate-ai-api

# Bcrypt
BCRYPT_ROUNDS=12

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/mindmate_ai?schema=public
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=mindmate:

# Rate Limiting
RATE_LIMIT_ANONYMOUS=10
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_PREMIUM=500
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_WINDOW_MS=60000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_FILE_PATH=./logs
LOG_MAX_FILES=30

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Email Service (SendGrid/AWS SES)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@mindmate.ai
EMAIL_FROM_NAME=MindMate AI
SENDGRID_API_KEY=

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI Service (Claude/OpenAI)
AI_PROVIDER=claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-opus-20240229
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Push Notifications
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=

# Monitoring & Analytics
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
FEATURE_MFA=true
FEATURE_OAUTH=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_ANALYTICS=true
FEATURE_CRISIS_DETECTION=true

# Crisis Support
CRISIS_HOTLINE_US=988
CRISIS_HOTLINE_UK=116123
CRISIS_HOTLINE_CA=8334564566

# Admin
ADMIN_DEFAULT_EMAIL=admin@mindmate.ai
ADMIN_DEFAULT_PASSWORD=change-this-password-immediately
