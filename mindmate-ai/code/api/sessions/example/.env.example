# MindMate AI Session Management - Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
MONGODB_URI=mongodb://localhost:27017/mindmate

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# AI Provider Configuration
# Options: anthropic, openai, azure
AI_PROVIDER=anthropic
AI_API_KEY=your-anthropic-api-key-here
AI_MODEL=claude-3-sonnet-20240229

# Alternative: OpenAI Configuration
# AI_PROVIDER=openai
# AI_API_KEY=your-openai-api-key-here
# AI_MODEL=gpt-4

# Azure OpenAI Configuration (if using Azure)
# AI_PROVIDER=azure
# AI_API_KEY=your-azure-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Rate Limiting
SESSION_RATE_LIMIT_WINDOW_MS=3600000
SESSION_RATE_LIMIT_MAX=10
MESSAGE_RATE_LIMIT_WINDOW_MS=60000
MESSAGE_RATE_LIMIT_MAX=30

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
