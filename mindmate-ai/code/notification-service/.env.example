# ============================================
# MindMate AI Notification Service - Environment
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3003
LOG_LEVEL=info

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/mindmate_notifications

# Firebase Configuration (FCM)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Apple Push Notification Service (APNs)
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.mindmate.app
APNS_PRODUCTION=false
APNS_KEY_PATH=/path/to/apns-key.p8

# Web Push Configuration
WEB_PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key
WEB_PUSH_SUBJECT=mailto:support@mindmate.ai

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid

# Queue Configuration
QUEUE_PREFIX=mindmate
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000
QUEUE_BACKOFF_TYPE=exponential

# Scheduler Configuration
CHECKIN_SCHEDULE=0 9 * * *
CHALLENGE_SCHEDULE=0 8 * * 1
TIMEZONE_DEFAULT=America/New_York

# Notification Limits
MAX_PUSH_PER_DAY=10
MAX_SMS_PER_DAY=3
MAX_EMAIL_PER_DAY=5
QUIET_HOURS_START=22
QUIET_HOURS_END=8

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Health Check
HEALTH_CHECK_INTERVAL=30000
