# MindMate AI Service - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Application Settings
# ============================================
APP_NAME=MindMate AI Service
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security
API_KEY=your-secure-api-key-here
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Claude API (Anthropic)
# ============================================
ANTHROPIC_API_KEY=sk-ant-api-your-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7
CLAUDE_TIMEOUT_SECONDS=60
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_DELAY_SECONDS=1.0
CLAUDE_MAX_CONTEXT_TOKENS=200000

# ============================================
# Pinecone Vector Database
# ============================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=mindmate-memories
PINECONE_NAMESPACE=
PINECONE_DIMENSION=1536
PINECONE_TOP_K=5

# ============================================
# Hume AI (Emotion Detection)
# ============================================
HUME_API_KEY=your-hume-api-key
HUME_WEBHOOK_SECRET=your-hume-webhook-secret
HUME_BATCH_SIZE=100

# ============================================
# ElevenLabs (Text-to-Speech)
# ============================================
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_TIMEOUT_SECONDS=30

# ============================================
# OpenAI (Embeddings)
# ============================================
OPENAI_API_KEY=sk-your-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# Redis (Caching/Sessions)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Crisis Detection
# ============================================
CRISIS_KEYWORDS=suicide,kill myself,end my life,want to die
CRISIS_CONFIDENCE_THRESHOLD=0.7

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
